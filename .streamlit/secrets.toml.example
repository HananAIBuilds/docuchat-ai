# Copy this file to .streamlit/secrets.toml (local dev) and fill in your key.
# On Streamlit Cloud, paste the same content into: App settings -> Secrets

GOOGLE_API_KEY = "your-google-api-key-here"

# Note: no HuggingFace token needed - embeddings run locally via
# sentence-transformers, not through HuggingFace's hosted API.
